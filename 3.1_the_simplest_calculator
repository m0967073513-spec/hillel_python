# ДЗ 3.1. Найпростіший калькулятор

x = float(input("Введіть перше число "))
y = float(input("Введіть друге число "))
perfomance = input("Введіть дію (+, -, *, /) ")

if perfomance == "+":
    print(x + y)
elif perfomance == "-":
    print(x - y)
elif perfomance == "*":
    print(x * y)
elif perfomance == "/":
    if y != 0:
        print(x / y)
    else:
        print("Ділення на нуль неможливе")

    
